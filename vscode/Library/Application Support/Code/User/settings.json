{
  "workbench.iconTheme": "vscode-icons",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "files.autoSave": "onFocusChange",
  "vsicons.presets.nestjs": true,
  "editor.stickyScroll.enabled": true,
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "git.autofetch": true,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "editor.inlineSuggest.enabled": true,
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "git.branchProtectionPrompt": "alwaysCommitToNewBranch",
  "githubPullRequests.pullBranch": "never",
  "diffEditor.ignoreTrimWhitespace": false,
  "window.nativeTabs": true,
  "python.venvPath": "/Users/neriyarden/dev/venvs",
  "python.venvFolders": ["/Users/neriyarden/dev/venvs"],
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false,
    "python": true,
  },
  "cSpell.userWords": [
    "AMPM",
    "Blankslate",
    "bogue",
    "Bookee",
    "Bookit",
    "consts",
    "firstname",
    "fullname",
    "hookform",
    "lastname",
    "marbletech",
    "nextjs",
    "roobert",
    "statsig",
    "SUBPRACTICE",
    "Substep",
    "Swiper",
    "tanstack",
    "Trustpilot",
    "usehooks",
    "Vinny",
  ],
  "editor.hover.delay": 400,
  "githubPullRequests.defaultCreateOption": "createDraft",
  "githubPullRequests.defaultMergeMethod": "squash",
  "githubPullRequests.commentExpandState": "collapseAll",
  "githubPullRequests.createOnPublishBranch": "never",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "nxConsole.showNodeVersionOnStartup": false,
  "CodeGPT.apiKey": "CodeGPT Plus",
  "CodeGPT.model": "CodeGPT Plus",
  "security.promptForLocalFileProtocolHandling": false,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
  },
  "github.copilot.chat.welcomeMessage": "always",
  "window.zoomLevel": 1,
  "window.title": "${folderName}",
  "git.confirmSync": false,
  "diffEditor.maxComputationTime": 0,
  "window.autoDetectColorScheme": true,
  "editor.acceptSuggestionOnCommitCharacter": false,
  "vscode_custom_css.imports": [
    "file:///Users/neriyarden/.vscode/extensions/brandonkirbyson.vscode-animations-2.0.1/dist/updateHandler.js",
  ],
  "animations.Scrolling": "Slide",
  "editor.minimap.enabled": false,
  "workbench.layoutControl.enabled": false,
  "turboConsoleLog.delimiterInsideMessage": "-",
  "turboConsoleLog.logMessagePrefix": "🌶️",
  "turboConsoleLog.quote": "'",
  "turboConsoleLog.insertEnclosingFunction": false,
  "turboConsoleLog.insertEnclosingClass": false,
  "codesnap.containerPadding": "0",
  "codesnap.backgroundColor": "#fff",
  "github.copilot.editor.enableAutoCompletions": true,
  "turbo.useLocalTurbo": true,
  "workbench.editor.wrapTabs": true,
  "workbench.editor.pinnedTabsOnSeparateRow": true,
  "eslint.options": {},
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "editor.formatOnSave": true,
  "github.copilot.advanced": {
    "authProvider": "github",
  },
  "gitlens.views.scm.grouped.views": {
    "commits": true,
    "branches": true,
    "remotes": true,
    "stashes": true,
    "tags": true,
    "worktrees": true,
    "contributors": true,
    "repositories": false,
    "searchAndCompare": true,
    "launchpad": false,
  },
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "totalTypeScript.hideAllTips": false,
  "totalTypeScript.hideBasicTips": true,
  "totalTypeScript.hiddenTips": [
    "passing-generics-to-types",
    "omit-utility-type",
    "partial-utility-type",
    "record-utility-type",
    "typeof",
    "pick-utility-type",
    "as-const",
    "as-const-on-object",
    "keyof",
    "generic-slots-in-functions",
    "non-null-expression",
    "conditional-type",
    "nested-conditional-type",
    "mapped-type",
  ],
  "github.copilot.nextEditSuggestions.enabled": true,
  "cSpell.enabledNotifications": {
    "Lines too Long": false,
    "Average Word Length too Long": false,
    "Maximum Word Length Exceeded": false,
  },
  "eslint.useFlatConfig": true,
  "eslint.execArgv": null,
  "claudeCode.useTerminal": true,
  "claudeCode.preferredLocation": "panel",
  "terminal.integrated.initialHint": false,
  "claudeCode.allowDangerouslySkipPermissions": true,
  "github.copilot.chat.claudeAgent.allowDangerouslySkipPermissions": true,
  "security.workspace.trust.untrustedFiles": "open",
  "json.schemaDownload.trustedDomains": {
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/": true,
    "https://www.schemastore.org/": true,
    "https://json.schemastore.org/": true,
    "https://json-schema.org/": true,
    "https://biomejs.dev": true,
  },
  "git.branchProtection": ["main"],
  "chat.tools.terminal.autoApprove": {
    "pnpm": true,
  },
  "redhat.telemetry.enabled": false,
}
